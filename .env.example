# 실제 값은 .env.local 에 넣는다 (.env.local 은 커밋되지 않음).
# 각 키 발급처는 주석 참고.

# DART 전자공시 — 재무제표·기업개황·종목 마스터 (opendart.fss.or.kr)
# 빌드 시 종목 마스터 생성(prebuild)과 런타임 재무 조회에 사용.
DART_API_KEY=

# KRX 공식 Open API — 시세(OHLCV·시총·52주 밴드) (openapi.krx.co.kr)
KRX_OPENAPI_KEY=

# Gemini API — 리포트 서술 생성 (aistudio.google.com)
GEMINI_API_KEY=
